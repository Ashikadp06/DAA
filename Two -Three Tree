#include <iostream>
using namespace std;

class Node {
public:
    int data[2];          // max 2 keys
    Node* child[3];       // max 3 children
    int n;                // number of keys

    Node(int val) {
        data[0] = val;
        n = 1;
        child[0] = child[1] = child[2] = NULL;
    }
};

class TwoThreeTree {
private:
    Node* root;

    // Insert helper
    Node* insert(Node* node, int val, int &upKey, Node* &newChild) {
        if (node == NULL) {
            upKey = val;
            newChild = NULL;
            return NULL;
        }

        int i;
        if (val < node->data[0])
            i = 0;
        else if (node->n == 1 || val < node->data[1])
            i = 1;
        else
            i = 2;

        Node* child = node->child[i];
        int newKey;
        Node* newNode = insert(child, val, newKey, newChild);

        if (newNode == NULL && newChild == NULL)
            return node;

        // Insert newKey into node
        if (node->n < 2) {
            // Insert in this node
            if (i == 0) {
                node->data[1] = node->data[0];
                node->data[0] = newKey;
                node->child[2] = node->child[1];
                node->child[1] = newChild;
            } else {
                node->data[1] = newKey;
                node->child[2] = newChild;
            }
            node->n++;
            return node;
        }

        // Split node
        int temp[3];
        Node* tempChild[4];

        for (int j = 0; j < 2; j++)
            temp[j] = node->data[j];

        for (int j = 0; j < 3; j++)
            tempChild[j] = node->child[j];

        // Insert new key in temp
        for (int j = 2; j > i; j--) {
            temp[j] = temp[j - 1];
            tempChild[j + 1] = tempChild[j];
        }

        temp[i] = newKey;
        tempChild[i + 1] = newChild;

        // Split into two nodes
        node->data[0] = temp[0];
        node->n = 1;
        node->child[0] = tempChild[0];
        node->child[1] = tempChild[1];

        Node* rightNode = new Node(temp[2]);
        rightNode->child[0] = tempChild[2];
        rightNode->child[1] = tempChild[3];

        upKey = temp[1];
        newChild = rightNode;

        return node;
    }

    void inorder(Node* node) {
        if (node == NULL)
            return;

        if (node->n == 1) {
            inorder(node->child[0]);
            cout << node->data[0] << " ";
            inorder(node->child[1]);
        } else {
            inorder(node->child[0]);
            cout << node->data[0] << " ";
            inorder(node->child[1]);
            cout << node->data[1] << " ";
            inorder(node->child[2]);
        }
    }

public:
    TwoThreeTree() {
        root = NULL;
    }

    void insert(int val) {
        int upKey;
        Node* newChild = NULL;

        Node* newRoot = insert(root, val, upKey, newChild);

        if (newChild != NULL) {
            Node* temp = new Node(upKey);
            temp->child[0] = root;
            temp->child[1] = newChild;
            root = temp;
        } else {
            root = newRoot;
        }
    }

    void display() {
        inorder(root);
        cout << endl;
    }
};

int main() {
    TwoThreeTree tree;

    int n, val;
    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements:\n";
    for (int i = 0; i < n; i++) {
        cin >> val;
        tree.insert(val);
    }

    cout << "Inorder Traversal: ";
    tree.display();

    return 0;
}
